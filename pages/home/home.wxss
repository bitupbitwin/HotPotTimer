.page {
  display: flex;
  flex-direction: row;
  height: 100vh;
  background: #121212;
}

/* ---------- 左侧分类栏 ---------- */
.rail {
  width: 152rpx;
  flex-shrink: 0;
  height: 100%;
  background: #171717;
}

.rail-item {
  margin: 6rpx 12rpx;
  min-height: 96rpx;
  border-radius: 16rpx;
  background: #222222;
  color: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 4rpx;
  box-sizing: border-box;
  text-align: center;
}

.rail-item.active {
  background: #ffcc00;
  color: #000000;
  font-weight: 800;
}

.rail-count {
  font-size: 22rpx;
  line-height: 1.2;
}

/* ---------- 右侧内容 ---------- */
.content {
  flex: 1;
  height: 100%;
}

.header {
  display: flex;
  align-items: center;
  padding: 24rpx 24rpx 16rpx;
}

.header-title {
  flex: 1;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 900;
}

.header-btn {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: #2a2a2a;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-left: 14rpx;
}

.header-btn.disabled {
  opacity: 0.35;
}

.section-title {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 800;
  padding: 8rpx 28rpx 16rpx;
}

/* ---------- 食材菜单网格 ---------- */
.menu-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  padding: 0 20rpx 40rpx;
}

.menu-tile {
  position: relative;
  background: #1e1e1e;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  padding: 12rpx 14rpx;
  min-height: 88rpx;
  box-sizing: border-box;
}

.menu-tile.selected {
  background: #332a00;
}

.menu-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #2a2a2a;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-avatar-img {
  width: 64rpx;
  height: 64rpx;
}

.menu-avatar-emoji {
  font-size: 34rpx;
  color: #ffffff;
  text-align: center;
  max-width: 64rpx;
  overflow: hidden;
}

.menu-name {
  flex: 1;
  margin-left: 12rpx;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.menu-qty {
  color: #ffcc00;
  font-size: 22rpx;
  font-weight: 900;
  margin-left: 8rpx;
}

.menu-mark {
  position: absolute;
  top: 8rpx;
  right: 10rpx;
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  border: 2rpx solid #666666;
  color: #888888;
  font-size: 22rpx;
  line-height: 28rpx;
  text-align: center;
}

.menu-mark.checked {
  border-color: #ffcc00;
  background: #ffcc00;
  color: #000000;
  font-weight: 900;
}

/* ---------- 已点计时区 ---------- */
.empty-box {
  margin: 8rpx 28rpx;
  height: 190rpx;
  border-radius: 16rpx;
  background: #1d1d1d;
  color: #9e9e9e;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 0 30rpx;
  box-sizing: border-box;
}

.timer-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 34rpx 20rpx;
  padding: 8rpx 20rpx 40rpx;
}

.timer-card {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 呼吸光圈：颜色状态机 */
.ring {
  width: 204rpx;
  height: 204rpx;
  border-radius: 50%;
  border: 16rpx solid #000000;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ring-counting {
  animation: blink-counting 1s ease-in-out infinite alternate;
}

.ring-ready {
  animation: blink-ready 2.8s ease-in-out infinite alternate;
}

.ring-overcooked {
  animation: blink-overcooked 0.4s ease-in-out infinite alternate;
}

@keyframes blink-counting {
  from {
    border-color: #7a6300;
    box-shadow: 0 0 10rpx rgba(255, 204, 0, 0.2);
  }
  to {
    border-color: #ffcc00;
    box-shadow: 0 0 32rpx rgba(255, 204, 0, 0.6);
  }
}

@keyframes blink-ready {
  from {
    border-color: rgba(76, 217, 100, 0.55);
    box-shadow: 0 0 12rpx rgba(76, 217, 100, 0.3);
  }
  to {
    border-color: #4cd964;
    box-shadow: 0 0 32rpx rgba(76, 217, 100, 0.6);
  }
}

@keyframes blink-overcooked {
  from {
    border-color: rgba(255, 59, 48, 0.15);
    box-shadow: 0 0 6rpx rgba(255, 59, 48, 0.1);
  }
  to {
    border-color: #ff3b30;
    box-shadow: 0 0 36rpx rgba(255, 59, 48, 0.65);
  }
}

.ring-inner {
  position: relative;
  width: 164rpx;
  height: 164rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #2a2a2a;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ring-img {
  width: 164rpx;
  height: 164rpx;
}

.ring-emoji {
  font-size: 64rpx;
  color: #ffffff;
  text-align: center;
  padding: 0 12rpx;
  max-height: 164rpx;
  overflow: hidden;
  word-break: break-all;
}

.ring-overlay {
  position: absolute;
  left: 0;
  top: 0;
  width: 164rpx;
  height: 164rpx;
  background: rgba(0, 0, 0, 0.3);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.overlay-time {
  color: rgba(255, 255, 255, 0.92);
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.05;
}

.overlay-label {
  color: rgba(255, 255, 255, 0.92);
  font-size: 28rpx;
  font-weight: 800;
  margin-top: 4rpx;
}

.overlay-label.danger {
  color: #ff3b30;
}

.qty-badge {
  position: absolute;
  left: 6rpx;
  top: 0;
  background: #ffcc00;
  color: #000000;
  font-size: 22rpx;
  font-weight: 900;
  border-radius: 999rpx;
  padding: 4rpx 14rpx;
}

.remove-btn {
  position: absolute;
  right: 6rpx;
  top: 0;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #3a3a3a;
  color: #ffffff;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.timer-name {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  margin-top: 10rpx;
}

.timer-target {
  color: #9e9e9e;
  font-size: 22rpx;
  margin-top: 2rpx;
}

.bottom-space {
  height: 40rpx;
}

/* ---------- 弹窗内部 ---------- */
.input-placeholder {
  color: #555555;
}

.confirm-list {
  max-height: 46vh;
}

.confirm-empty {
  color: #9e9e9e;
  font-size: 26rpx;
  padding: 20rpx 0;
}

.confirm-row {
  display: flex;
  align-items: center;
  padding: 18rpx 4rpx;
  border-bottom: 2rpx solid #2a2a2a;
}

.confirm-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
  border: 2rpx solid #555555;
  color: #000000;
  font-size: 28rpx;
  line-height: 38rpx;
  text-align: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.confirm-check.on {
  background: #ffcc00;
  border-color: #ffcc00;
  font-weight: 900;
}

.confirm-info {
  flex: 1;
}

.confirm-name {
  color: #ffffff;
  font-size: 28rpx;
}

.confirm-sub {
  color: #888888;
  font-size: 23rpx;
  margin-top: 4rpx;
}

.manager-delete {
  color: #ff6b60;
  font-size: 25rpx;
  padding: 10rpx 16rpx;
}
